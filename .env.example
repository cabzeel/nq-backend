# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/nq_shop?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRE=30d

# ── Cloudinary (free at cloudinary.com) ──────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── MTN MoMo (sandbox → momodeveloper.mtn.com) ───────────
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MOMO_API_USER=your_api_user_uuid
MOMO_API_KEY=your_momo_api_key
MOMO_ENVIRONMENT=sandbox
# Set to your deployed backend URL when live, e.g. https://nq-api.vercel.app
MOMO_CALLBACK_URL=https://your-backend.vercel.app/api/payments/momo/callback
MOMO_CURRENCY=XAF

# ── CORS ──────────────────────────────────────────────────
# Your deployed Vercel frontend URL
CLIENT_URL=https://your-frontend.vercel.app

# ── Admin seed (used on first start) ─────────────────────
ADMIN_EMAIL=admin@nqshop.com
ADMIN_PASSWORD=ChangeMe@2025
